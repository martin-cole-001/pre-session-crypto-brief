generator client {
  provider = "prisma-client-js"
  output   = "../app/src/generated/prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SessionOverview {
  id              String   @id @default(uuid())
  session         String
  status          String
  outputJson      String
  humanReport     String?
  inputSnapshotId String?
  telegramPostIds String   @default("[]")
  promptVersion   String?
  model           String?
  createdAt       DateTime @default(now())
}

model OverviewInput {
  id        String   @id @default(uuid())
  session   String
  inputJson String
  savedAt   DateTime @default(now())
}

model CollectedEvent {
  id             String   @id @default(uuid())
  eventId        String
  eventType      String
  category       String
  title          String
  source         String
  relevanceScore Float
  dedupeKey      String
  rawJson        String
  collectedAt    DateTime @default(now())
}

model CollectorRun {
  id            String    @id @default(uuid())
  collectorName String
  startedAt     DateTime
  finishedAt    DateTime?
  status        String
  itemCount     Int
  errorMessage  String?
  durationMs    Int?
  createdAt     DateTime  @default(now())
}

model TelegramOverviewPost {
  id         String   @id @default(uuid())
  overviewId String
  messageId  String
  chatId     String
  session    String
  postedAt   DateTime @default(now())
}

model OverviewLlmUsage {
  id              String   @id @default(uuid())
  overviewId      String
  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  durationMs      Int
  promptVersion   String?
  createdAt       DateTime @default(now())
}

model ActiveSetup {
  id              String   @id @default(uuid())
  setupId         String   @unique
  symbol          String
  direction       String
  setupType       String
  timeframeSource String
  status          String
  relevantZoneLow Float?
  relevantZoneHigh Float?
  invalidation    Float?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model SchedulerLock {
  id          String   @id
  lockedAt    DateTime
  expiresAt   DateTime
}
